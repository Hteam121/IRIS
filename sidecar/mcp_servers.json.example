{
  "_comment": "Copy to mcp_servers.json and fill in. Each key is an MCP server the agent loads tools from. Google Calendar example below uses the @cocal/google-calendar-mcp npm server via npx; first run opens a Google OAuth consent screen. See README.md.",
  "google-calendar": {
    "command": "npx",
    "args": ["-y", "@cocal/google-calendar-mcp"],
    "transport": "stdio",
    "env": {
      "GOOGLE_OAUTH_CREDENTIALS": "~/.iris/gcp-oauth.keys.json"
    }
  }
}
