# IRIS sidecar environment (copy to .env; IRIS also passes these when it spawns the sidecar)

# Required for any real agent work:
ANTHROPIC_API_KEY=

# Model the agents reason with (foreground IRIS Q&A stays on claude-sonnet-4-6):
IRIS_AGENT_MODEL=claude-opus-4-8

# Max agents running at once (extras queue):
IRIS_MAX_AGENTS=4

# Server bind (IRIS connects here):
IRIS_SIDECAR_HOST=127.0.0.1
IRIS_SIDECAR_PORT=8765

# Optional: richer web search (else DuckDuckGo, no key):
# TAVILY_API_KEY=

# Optional: absolute path to the claude binary for the terminal-launch tool:
# IRIS_CLAUDE_BINARY=/Users/you/.local/bin/claude
