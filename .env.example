# IRIS configuration — copy to `.env` and edit, or place equivalent JSON at ~/.iris/config.json
# Every value is OPTIONAL; IRIS falls back to the defaults shown below.
# `.env` is git-ignored and read at launch by Settings (see IRIS/Config/Settings.swift).

# --- AI routing (Hybrid) ---------------------------------------------------
# If ANTHROPIC_API_KEY is set, IRIS uses the Anthropic Messages API with true
# base64 screen vision. If it is empty/unset, IRIS falls back to the `claude -p`
# CLI (your Claude subscription) with the screenshot passed as a temp PNG path.
ANTHROPIC_API_KEY=

# OPENAI_API_KEY is only used for the natural neural voice (gpt-4o-mini-tts).
# Optional — without it, IRIS speaks with the built-in macOS voice. Command routing
# is fully deterministic and needs no key. Never committed (.env is git-ignored).
OPENAI_API_KEY=

# Model used for replies. Default is the balanced Sonnet; switch to Haiku for
# lower latency / cost.
#   default: claude-sonnet-4-6
#   fast:    claude-haiku-4-5-20251001
IRIS_MODEL=claude-sonnet-4-6

# Optional explicit path to the `claude` binary. Leave empty to auto-resolve
# (~/.local/bin, /opt/homebrew/bin, /usr/local/bin, then `zsh -lic 'which claude'`).
IRIS_CLAUDE_BINARY=

# --- Triggers --------------------------------------------------------------
# Case-insensitive phrase that arms command capture. Keep it short and distinct.
# The default also accepts common mishearings (hey dori/dorie/dorey/dora).
IRIS_WAKE_PHRASE=hey dory
# Also wake on the bare name ANYWHERE in a sentence ("…, Dory?"). 1 = on.
IRIS_WAKE_NAME_ONLY=1
# Push-to-talk chord: hold this key + modifiers to talk (no wake phrase needed).
# Defaults: keycode 49 (Space) with the Option modifier (⌥Space).
IRIS_PTT_KEYCODE=49
IRIS_PTT_MODIFIERS=524288

# --- UI --------------------------------------------------------------------
# Main surface: "buddy" (cursor-following orb + caption, default) or "notch"
# (island anchored over the camera notch).
IRIS_UI_MODE=buddy

# --- Budget ----------------------------------------------------------------
# Hard monthly cap (USD) for paid API spend (TTS + Anthropic API when keyed).
# 0 = unlimited. The claude CLI path is always free with a subscription.
IRIS_MONTHLY_BUDGET=20

# --- Text-to-speech --------------------------------------------------------
# Voice language/locale for AVSpeechSynthesizer.
IRIS_VOICE=en-US
# Optional explicit AVSpeechSynthesisVoice identifier (overrides language-based
# selection). Use this to pin a downloaded premium/Siri voice, e.g.
#   com.apple.voice.premium.en-US.Ava
# Leave empty to auto-pick the best installed voice for IRIS_VOICE.
IRIS_VOICE_ID=
# Speaking rate, 0.0–1.0 (AVSpeechUtterance scale). 0.52 ≈ natural pace.
IRIS_TTS_RATE=0.52

# --- Screen pointing / skills / local-first --------------------------------
# Animated on-screen pointer ("where's the WiFi icon?").
IRIS_POINTER=1
# Markdown skills at ~/.iris/skills/ (bundled examples seeded on first launch).
IRIS_SKILLS=1
# Answer simple questions with a free local model first (Ollama / Apple FM),
# escalating to the cloud when needed.
IRIS_LOCAL_LLM=1
# Ollama model for local answers (falls back to the first installed model).
IRIS_LOCAL_MODEL=llama3.2
# Where Ollama serves.
IRIS_OLLAMA_URL=http://localhost:11434
